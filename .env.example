# Garmin credentials
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password

# Strava credentials (if using Strava sync)
# Create a Strava app at https://developers.strava.com/docs/getting-started/
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# Google Sheet ID, found in https://docs.google.com/spreadsheets/d/<ID>
SPREADSHEET_ID=your_sheet_id